{
  "name": "famtrack",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "server:build": "tsc -p tsconfig.server.json",
    "server:start": "node dist-server/server/index.js",
    "test:server": "npm run server:build && node --test dist-server/server/*.test.js",
    "build": "vite build",
    "preview": "vite preview",
    "check": "npm run typecheck && npm run test:server && npm run build",
    "typecheck": "tsc --noEmit --pretty false"
  },
  "dependencies": {
    "@tanstack/react-query": "5.0.0",
    "lucide-react": "^0.554.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "sql.js": "^1.13.0"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@types/sql.js": "^1.4.9",
    "@vitejs/plugin-react": "^5.0.0",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
