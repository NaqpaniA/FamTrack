{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM"],
    "skipLibCheck": true,
    "types": ["node"],
    "jsx": "react-jsx",
    "allowJs": false,
    "strict": false,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "outDir": "dist-server",
    "rootDir": "."
  },
  "include": [
    "server/**/*.ts",
    "data.ts",
    "types.ts",
    "tasks.model.ts",
    "finance.model.ts",
    "family.model.ts",
    "shopping.model.ts",
    "events.model.ts",
    "notes.model.ts"
  ]
}
